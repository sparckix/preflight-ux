{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetic-ux-panels.local/schemas/known-issues.schema.json",
  "title": "Preflight UX Benchmark Known Issues",
  "type": "object",
  "required": ["issues"],
  "additionalProperties": false,
  "properties": {
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "class", "description", "severity", "surfaced_by", "sources"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "class": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["minor", "moderate", "severe"]
          },
          "surfaced_by": {
            "type": "string",
            "minLength": 1
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "url", "date"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "minLength": 1 },
                "date": { "type": "string", "minLength": 1 }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
