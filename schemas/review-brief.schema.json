{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preflight-ux.local/schemas/review-brief.schema.json",
  "title": "Preflight UX Review Brief",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "prompt_version",
    "product",
    "attachments",
    "review",
    "panel"
  ],
  "additionalProperties": true,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "preflight_ux_review_brief"
    },
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "prompt_version": {
      "type": "string",
      "minLength": 1
    },
    "product": {
      "type": "object",
      "required": [
        "name",
        "audience",
        "stage",
        "surface_type",
        "prototype_url",
        "surface"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": [
            "pre-ship",
            "prototype",
            "redesign",
            "post-launch"
          ]
        },
        "surface_type": {
          "type": "string",
          "enum": [
            "benchmark",
            "url",
            "screenshot",
            "spec",
            "prototype",
            "pr"
          ]
        },
        "prototype_url": {
          "type": "string"
        },
        "surface": {
          "type": "string"
        }
      }
    },
    "attachments": {
      "type": "object",
      "required": [
        "screenshots"
      ],
      "additionalProperties": false,
      "properties": {
        "screenshots": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": [
              "name",
              "mime_type",
              "size_bytes"
            ],
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "mime_type": {
                "type": "string",
                "enum": [
                  "image/png",
                  "image/jpeg",
                  "image/webp"
                ]
              },
              "size_bytes": {
                "type": "number",
                "maximum": 1800000
              },
              "data_url": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "depth",
        "synthesis_mode"
      ],
      "additionalProperties": false,
      "properties": {
        "depth": {
          "type": "string",
          "enum": [
            "fast",
            "deep"
          ]
        },
        "synthesis_mode": {
          "type": "string",
          "enum": [
            "prioritized",
            "disagreement",
            "adversarial"
          ]
        }
      }
    },
    "panel": {
      "type": "object",
      "required": [
        "personas",
        "risk_focus"
      ],
      "additionalProperties": false,
      "properties": {
        "personas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "risk_focus": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
