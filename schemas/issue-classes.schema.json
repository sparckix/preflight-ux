{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetic-ux-panels.local/schemas/issue-classes.schema.json",
  "title": "Preflight UX Issue Taxonomy",
  "type": "object",
  "required": ["version", "classes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": ["string", "number"]
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slug",
          "category",
          "definition",
          "counts",
          "does_not_count",
          "severity_guidance",
          "aliases"
        ],
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "counts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "does_not_count": {
            "type": "array",
            "items": { "type": "string" }
          },
          "severity_guidance": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          }
        }
      }
    }
  }
}
